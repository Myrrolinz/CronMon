# CronMon — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored. Never commit it with real secrets.
# All variables are optional unless marked (required).

# ── Server ────────────────────────────────────────────────────────────────────

# Port the HTTP server listens on.
# Default: 8080
PORT=8080

# Path to the SQLite database file.
# Default: cronmon.db
DB_PATH=cronmon.db

# Public base URL of your CronMon instance. Used to build ping URLs.       (required)
# Example: https://cronmon.example.com
BASE_URL=

# ── Scheduler ─────────────────────────────────────────────────────────────────

# How often (in seconds) the missed-ping scheduler runs. Minimum: 10.
# Default: 30
SCHEDULER_INTERVAL=30

# ── Authentication ────────────────────────────────────────────────────────────

# Username for the web dashboard (HTTP Basic Auth).
# Default: admin
ADMIN_USER=admin

# Password for the web dashboard. Must be non-empty.                        (required)
ADMIN_PASS=

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# All SMTP_* variables are optional.
# If any of SMTP_HOST, SMTP_USER, SMTP_PASS, or SMTP_FROM is set,
# then both SMTP_HOST and SMTP_FROM become required.

# SMTP server hostname.
# Example: smtp.gmail.com
SMTP_HOST=

# SMTP server port.
# Default: 587
SMTP_PORT=587

# SMTP username (if your server requires authentication).
SMTP_USER=

# SMTP password (if your server requires authentication).
SMTP_PASS=

# Sender address for alert emails.
# Example: cronmon@example.com
SMTP_FROM=

# Enable STARTTLS on the SMTP connection. Set to "false" only for local/test
# SMTP servers that do not support TLS.
# Default: true
SMTP_TLS=true

# ── Security ──────────────────────────────────────────────────────────────────

# Set to "true" if CronMon is behind a trusted reverse proxy (nginx, Caddy,
# etc.) that sets the X-Forwarded-For header. Used to record the real client
# IP on ping requests.
# Default: false
TRUSTED_PROXY=false

# Set to "true" to require HTTPS for all requests. Useful when running behind
# a reverse proxy that handles TLS termination.
# Default: false
REQUIRE_HTTPS=false

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error
# Default: info
LOG_LEVEL=info
